---
import Layout from '../../layouts/Layout.astro';
import { getCategories } from '../../lib/api.js';

let categories = [];
try {
  categories = await getCategories();
} catch {}
---

<Layout>
  <h1 class="text-3xl font-bold mb-2">📁 分类</h1>
  <p class="text-gray-400 text-sm mb-8">按分类浏览文章</p>
  <div class="grid gap-3 sm:grid-cols-2">
    {categories.length === 0 && <p class="text-gray-400 col-span-full text-center py-16">暂无分类</p>}
    {categories.map((c) => (
      <a
        href={`/categories/${c.slug}`}
        class="group flex justify-between items-center bg-white rounded-xl border border-gray-100 px-5 py-4 hover:shadow-md hover:border-blue-100 transition-all duration-300"
      >
        <span class="font-medium text-gray-800 group-hover:text-blue-600 transition-colors">{c.name}</span>
        <span class="inline-flex items-center justify-center min-w-[2rem] h-6 px-2 rounded-full bg-gray-100 text-xs text-gray-500 group-hover:bg-blue-50 group-hover:text-blue-600 transition-all">{c._count?.posts ?? 0} 篇</span>
      </a>
    ))}
  </div>
</Layout>