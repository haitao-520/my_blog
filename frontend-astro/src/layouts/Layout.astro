---
import '../styles/global.css';
import { getSiteSettings } from '../lib/settings.js';

const { siteTitle, siteDesc, authorName, adminUrl: rawAdminUrl } = await getSiteSettings();
// 生产环境自动适配：如果 adminUrl 还是 localhost 但当前域名不是本地，自动用当前域名+5173
const isLocal = Astro.url.hostname === 'localhost' || Astro.url.hostname === '127.0.0.1';
const adminUrl = isLocal ? 'http://localhost:5173' : '/admin';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-800">
    <!-- 导航 -->
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-lg border-b border-gray-100 shadow-sm">
      <nav class="max-w-5xl mx-auto px-5 h-14 flex items-center justify-between text-sm font-medium">
          <a href="/" class="px-2 sm:px-3 py-1 sm:py-1.5 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-all">首页</a>
          <a href="/categories" class="px-2 sm:px-3 py-1 sm:py-1.5 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-all">分类</a>
          <a href="/archive" class="px-2 sm:px-3 py-1 sm:py-1.5 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-all">归档</a>
          <a href="/search" class="px-2 sm:px-3 py-1 sm:py-1.5 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-all">搜索</a>
          <a href="/about" class="px-2 sm:px-3 py-1 sm:py-1.5 rounded-lg text-gray-500 hover:text-blue-600 hover:bg-blue-50 transition-all flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span class="hidden sm:inline">关于</span>作者
          </a>
          <a href={adminUrl} class="shrink-0" title="管理后台">
            <img src="/avatar.jpg" alt={authorName} class="w-8 h-8 sm:w-9 sm:h-9 rounded-lg object-cover shadow-md hover:ring-2 hover:ring-blue-400 transition-all" />
          </a>
        </nav>
    </header>

    <!-- 主内容 -->
    <main class="flex-1 max-w-5xl mx-auto px-5 py-8 w-full">
      <slot />
    </main>

    <!-- 页脚 -->
    <footer class="border-t border-gray-200 bg-white">
      <div class="max-w-5xl mx-auto px-5 py-6 text-center text-sm text-gray-500">
        <p>&copy; 2026 {authorName || siteTitle}. Powered by Astro &amp; Vue.</p>
        <p class="mt-1">
          👁️ 全站访问 <span id="site-views">···</span> 次
        </p>
      </div>
    </footer>
  </body>
</html>

<script>
  // 全站访问量统计（同会话只记一次）
  (async () => {
    const el = document.getElementById('site-views');
    try {
      const res = await fetch('/api/stats/public');
      const data = await res.json();
      if (el) el.textContent = (data.siteViews || 0).toLocaleString();
    } catch { if (el) el.textContent = '-'; }

    // 记录访问（sessionStorage 去重）
    if (!sessionStorage.getItem('_sv')) {
      sessionStorage.setItem('_sv', '1');
      try { await fetch('/api/stats/site-view', { method: 'POST' }); } catch {}
    }
  })();
</script>